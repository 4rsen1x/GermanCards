# Supabase credentials (required for cloud sync & auth)
# Get these from: https://supabase.com/dashboard/project/_/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# GitHub Pages base URL — set to /your-repo-name/ for project sites
# Leave as / for user/org sites (username.github.io)
VITE_BASE_URL=/GermanCards/
